# =============================================================================
# Environment Variables — Proxmox + LXC Deployment
# Copy this file to .env on each relevant LXC and fill in all values.
# Generate secrets with: openssl rand -base64 48
# =============================================================================

# --- Public Domain ---
APP_DOMAIN=kanban.yourdomain.com
PLANKA_BASE_URL=https://kanban.yourdomain.com

# --- Internal LXC Hosts (adjust IPs to match your Proxmox network) ---
DB_HOST=10.0.10.10
DB_PORT=5432
REDIS_HOST=10.0.10.10
REDIS_PORT=6379
PLANKA_HOST=10.0.10.11
BFF_HOST=10.0.10.12
PROXY_HOST=10.0.10.13

# --- PostgreSQL ---
POSTGRES_USER=planka
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=planka

# --- Redis ---
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- Planka ---
PLANKA_SECRET_KEY=REPLACE_WITH_64_CHAR_SECRET
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DEFAULT_ADMIN_NAME=Admin
DEFAULT_ADMIN_USERNAME=admin

# --- BFF ---
BFF_JWT_SECRET=REPLACE_WITH_64_CHAR_SECRET
JWT_EXPIRES_IN=7d
ICAL_SECRET=REPLACE_WITH_32_CHAR_SECRET

# --- LINE (from LINE Developers console) ---
LINE_CHANNEL_ID=your_line_login_channel_id
LINE_CHANNEL_SECRET=your_line_login_channel_secret
LINE_MESSAGING_TOKEN=your_messaging_api_long_lived_token

# --- LIFF (for BFF deep links and frontend build) ---
VITE_LIFF_ID=your_liff_id

# --- HR: Office GPS (optional — skip if allow_remote=true per org) ---
OFFICE_LAT=13.7563
OFFICE_LNG=100.5018
OFFICE_RADIUS_M=300
